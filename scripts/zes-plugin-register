#!/usr/bin/env python3
"""ZES Plugin Registration - Register an MCP service as a dashboard plugin"""
import json
import sys
import urllib.request

args = sys.argv[1:]

name = args[0] if len(args) > 0 else __import__('socket').gethostname()
version = args[1] if len(args) > 1 else "0.1"
description = args[2] if len(args) > 2 else "ZES system component"
widgets = json.loads(args[3]) if len(args) > 3 else [{"id": "main", "name": "Dashboard"}]
endpoints = json.loads(args[4]) if len(args) > 4 else {}

data = json.dumps({
    "name": name,
    "version": version,
    "description": description,
    "widgets": widgets,
    "endpoints": endpoints
}).encode()

req = urllib.request.Request(
    "http://127.0.0.1:8083/api/plugins/register",
    data=data,
    headers={"Content-Type": "application/json"}
)
try:
    r = urllib.request.urlopen(req, timeout=5)
    result = json.loads(r.read())
    print(json.dumps(result, indent=2))
except Exception as e:
    print(f"Error: {e}")
