PROVIDERS = [
    {"name": "Groq", "key_env": "GROQ_API_KEY", "model": "Llama 3.3 70B"},
    {"name": "OpenRouter", "key_env": "OPENROUTER_API_KEY", "model": "DeepSeek V4 Flash"},
