#!/data/data/com.termux/files/usr/bin/python3
"""
ZES Unified Status Dashboard — All 11 tools, providers, services, resources at a glance.

Usage:
  zes status                              # Full unified dashboard
  zes status --json                       # JSON output for web widgets
  zes status --watch                      # Live-refresh mode (every 5s)
  zes status --simple                     # One-line compact summary
"""

