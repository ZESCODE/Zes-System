        "model": os.environ.get("USAGE_MODEL", "llama-3.3-70b-versatile"),
        "env_key": "GROQ_API_KEY",
        "name": "Usage Analyzer (Groq Llama 3.3)",
    },
    "optimizer": {
        "url": os.environ.get("OPTIMIZER_URL", "https://openrouter.ai/api/v1/chat/completions"),
        "model": os.environ.get("OPTIMIZER_MODEL", "deepseek/deepseek-v4-flash"),
        "env_key": "OPENROUTER_API_KEY",
        "name": "Cost Optimizer (OpenRouter DeepSeek V4)",
    },
    "forecaster": {
        "url": os.environ.get("FORECAST_URL", "https://api.llm7.io/v1/chat/completions"),
        "model": os.environ.get("FORECAST_MODEL", "codestral-latest"),
        "env_key": "LLM7_API_KEY",
        "name": "Budget Forecaster (LLM7 Codestral)",
    },
}

