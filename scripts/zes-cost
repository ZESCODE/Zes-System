#!/data/data/com.termux/files/usr/bin/python3
"""
ZES Cost Tracker — 3-Agent Cost Analysis Engine.

Spawns 3 parallel AI agents to track, optimize, and forecast API costs:
  Usage Analyzer    → Token/cost estimates per provider, per command, trends
  Cost Optimizer    → Routing optimization, provider comparison, savings
  Budget Forecaster → Monthly projections, anomaly detection, alerts

Usage:
  zes cost                                # Full cost analysis
  zes cost --report                       # Generate detailed report file
  zes cost --quick                        # Quick cost summary
  zes cost --alerts                       # Show active alerts
"""

import asyncio, json, os, sys, argparse, textwrap, subprocess, re
from datetime import datetime, timedelta
from pathlib import Path
from typing import Optional

