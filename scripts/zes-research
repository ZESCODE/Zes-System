#!/data/data/com.termux/files/usr/bin/python3
"""ZES Parallel Research Engine — Multi-Model Sub-Agent Swarm.

Spawns N parallel AI agents across different providers/models to research
a topic from multiple angles, then synthesizes results into a final report.

Usage:
  zes-research "What is the impact of AI on healthcare?"
  zes-research "Topic" --agents 4
  zes-research "Topic" --output ~/research.md --silent
  zes-research "Topic" --providers bitrouter_gpt openrouter_key groq_key
"""

import asyncio, aiohttp, json, sys, os, argparse, textwrap, subprocess, re
from datetime import datetime
from typing import Optional

# ─── Load API Keys ────────────────────────────────────────────────
def _load_env():
    """Load master.env into os.environ."""
    env_file = os.path.expanduser("~/.secure-credentials/master.env")
    if os.path.exists(env_file):
        with open(env_file) as f:
            for line in f:
                line = line.strip()
                if line.startswith("export "):
                    parts = line[7:].split("=", 1)
                    if len(parts) == 2:
                        val = parts[1].strip("\"'")
                        if val:
                            os.environ.setdefault(parts[0], val)
_load_env()

# ─── Provider Config ───────────────────────────────────────────────
