  .value { color: var(--text); }
  .bar-container { display: flex; align-items: center; gap: 8px; width: 100%; }
  .bar { height: 6px; border-radius: 3px; flex: 1; background: #2a2a4a; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 3px; transition: width 1s ease; }
  .bar-fill.green { background: var(--green); }
  .bar-fill.yellow { background: var(--yellow); }
  .bar-fill.red { background: var(--red); }
  .health-badge { display: inline-block; padding: 2px 10px; border-radius: 4px; font-size: 11px; font-weight: bold; text-transform: uppercase; }
  .health-badge.healthy { background: rgba(74,222,128,0.15); color: var(--green); }
  .health-badge.degraded { background: rgba(251,191,36,0.15); color: var(--yellow); }
  .health-badge.critical { background: rgba(248,113,113,0.15); color: var(--red); }
  .timestamp { color: var(--dim); font-size: 11px; text-align: center; margin-top: 12px; }
  .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .header h1 { font-size: 16px; }
  .header .refresh-btn { cursor: pointer; padding: 4px 12px; border: 1px solid var(--border); border-radius: 4px; background: var(--card); color: var(--text); font-family: inherit; font-size: 11px; }
  .header .refresh-btn:hover { background: var(--border); }
  .count { font-size: 18px; font-weight: bold; }
  .count-label { font-size: 10px; color: var(--dim); text-transform: uppercase; }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 12px; }
  .stat { text-align: center; padding: 8px; background: rgba(255,255,255,0.03); border-radius: 6px; }
  .stat .count { font-size: 20px; }
  .flex { display: flex; gap: 8px; flex-wrap: wrap; }
</style>
</head>
<body>
<div class="header">
  <h1>🏛️ ZES Status</h1>
  <div>
    <span id="healthBadge"></span>
    <button class="refresh-btn" onclick="refresh()">⟳ Refresh</button>
  </div>
</div>

<div class="stats" id="stats"></div>

<div class="grid">
  <div class="card">
    <h3>🛠️ Cache Status</h3>
    <div id="cacheStatus">
      <p style="color: var(--dim)">Loading...</p>
    </div>
  </div>
  <div class="card">
    <h3>🛠️ Commands</h3>
    <div id="tools"></div>
  </div>
  <div class="card">
    <h3>🌐 Services</h3>
    <div id="services"></div>
  </div>
  <div class="card">
    <h3>🖥️ System</h3>
    <div id="system"></div>
  </div>
</div>
<div class="timestamp" id="timestamp"></div>

<script>
async function refresh() {
  try {
    document.querySelector('.refresh-btn').textContent = '⟳ ...';
    const resp = await fetch('/api/status');
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const d = await resp.json();
    render(d);
  } catch(e) {
    document.getElementById('tools').innerHTML = `<p style="color: var(--red)">Error: ${e.message}</p>`;
  }
  document.querySelector('.refresh-btn').textContent = '⟳ Refresh';
}

function render(d) {
  // Health badge
  const badge = document.getElementById('healthBadge');
  badge.innerHTML = `<span class="health-badge ${d.health}">${d.health}</span>`;

  // Stats
  document.getElementById('stats').innerHTML = `
    <div class="stat"><div class="count">${d.summary.commands_today}</div><div class="count-label">Today</div></div>
    <div class="stat"><div class="count">${d.tools.filter(t => t.installed).length}</div><div class="count-label">Tools</div></div>
    <div class="stat"><div class="count">${d.providers_ok}</div><div class="count-label">Providers</div></div>
    <div class="stat"><div class="count">${d.services_up}</div><div class="count-label">Services</div></div>
  `;

  // Cache status 
  document.getElementById('cacheStatus').innerHTML = renderCacheStatus(d);

  // Tools
  document.getElementById('tools').innerHTML = d.tools.map(t => `
    <div class="row">
      <span class="status-dot ${t.installed ? 'up' : 'down'}"></span>
      <span class="label" style="width:80px">${t.command}</span>
      <span class="value" style="flex:1">${t.description}</span>
      <span style="color:var(--dim);font-size:11px">${t.runs > 0 ? t.runs + 'x' : ''}</span>
    </div>
  `).join('');

  // Services
  document.getElementById('services').innerHTML = d.services.map(s => `
    <div class="row">
      <span class="status-dot ${s.status}"></span>
      <span class="label" style="width:80px">:${s.port}</span>
      <span class="value" style="flex:1">${s.name}</span>
      <span style="color:var(--dim);font-size:11px">${s.latency_ms ? s.latency_ms + 'ms' : s.error || '—'}</span>
    </div>
  `).join('');

  // System
  const sys = d.system;
  const memPct = sys.mem_used_pct || 0;
  const memBarClass = memPct < 70 ? 'green' : memPct < 85 ? 'yellow' : 'red';
  let diskPct = 0;
  if (sys.disk_pct) diskPct = parseInt(sys.disk_pct);
  const diskBarClass = diskPct < 70 ? 'green' : diskPct < 85 ? 'yellow' : 'red';

  document.getElementById('system').innerHTML = `
    <div class="row">
      <span class="label">🧠 Memory</span>
      <div class="bar-container">
        <div class="bar"><div class="bar-fill ${memBarClass}" style="width:${memPct}%"></div></div>
        <span style="color:var(--dim);font-size:11px;width:50px">${memPct}%</span>
      </div>
    </div>
    <div class="row">
      <span class="label">💾 Disk</span>
      <div class="bar-container">
        <div class="bar"><div class="bar-fill ${diskBarClass}" style="width:${diskPct}%"></div></div>
        <span style="color:var(--dim);font-size:11px;width:50px">${sys.disk_pct || '?'}</span>
      </div>
    </div>
    <div class="row"><span class="label">⏱ Load</span><span>${sys.load_1m || '?'} / ${sys.load_5m || '?'} / ${sys.load_15m || '?'}</span></div>
    <div class="row"><span class="label">🕐 Up</span><span>${sys.uptime || '?'}</span></div>
    ${sys.memory_hub_size_mb ? `<div class="row"><span class="label">🧩 Memory</span><span>${sys.memory_hub_size_mb} MB</span></div>` : ''}
  `;

  // Timestamp
  document.getElementById('timestamp').textContent = 'Last updated: ' + new Date(d.timestamp).toLocaleTimeString();
}

function renderCacheStatus(d) {
  if (!d.cache) return '<p style="color: var(--dim)">No cache data</p>';
  const c = d.cache;
  return Object.entries(c).map(([key, val]) => `
    <div class="row">
      <span class="status-dot ${val.status === 'ready' ? 'up' : val.status === 'warming' ? 'degraded' : 'down'}"></span>
      <span class="label" style="width:100px">${key}</span>
      <span class="value">${val.message || val.status}</span>
    </div>
  `).join('');
}

// Auto-refresh every 30s
refresh();
setInterval(refresh, 30000);
</script>
</body>
</html>
"""

def get_status_json():
    """Execute zes-status --json and return parsed data."""
    try:
        proc = subprocess.run(
            [sys.executable, str(Path.home() / ".local" / "bin" / "zes-status"), "--json"],
            capture_output=True, text=True, timeout=15,
            env={**os.environ},
        )
        if proc.returncode == 0 and proc.stdout.strip():
            return json.loads(proc.stdout)
        return {"error": f"status tool exit {proc.returncode}", "stderr": proc.stderr[:200]}
    except Exception as e:
        return {"error": str(e)}


class StatusHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        path = parsed.path.rstrip("/")
        
        if path == "/api/status":
            data = get_status_json()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Access-Control-Allow-Origin", "*")
            self.send_header("Cache-Control", "no-cache")
            self.end_headers()
            self.wfile.write(json.dumps(data).encode())
        elif path == "" or path == "/":
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.end_headers()
            self.wfile.write(HTML_PAGE.encode())
        else:
            self.send_response(404)
            self.send_header("Content-Type", "text/plain")
            self.end_headers()
            self.wfile.write(b"404 Not Found - try / or /api/status")
    
    def log_message(self, format, *args):
        if args and "200" == args[1]:
            return  # Quiet normal requests
        sys.stderr.write(f"[{self.log_date_time_string()}] {args[0]} {args[1]} {args[2]}\n")


def main():
    parser = argparse.ArgumentParser(description="ZES Status Widget Server")
    parser.add_argument("--port", "-p", type=int, default=PORT, help=f"Port (default: {PORT})")
    parser.add_argument("--no-open", action="store_true", help="Don't print URL")
    args = parser.parse_args()
    
    server = http.server.HTTPServer(("127.0.0.1", args.port), StatusHandler)
    
    if not args.no_open:
        print(f"  🏛️  ZES Status Widget: http://127.0.0.1:{args.port}")
        print(f"  📡 JSON API:          http://127.0.0.1:{args.port}/api/status")
    
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n  👋 Stopped.")
        server.server_close()


if __name__ == "__main__":
    main()