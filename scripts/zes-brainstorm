#!/data/data/com.termux/files/usr/bin/python3
"""
ZES Brainstorming — 3-Agent Divergent Thinking Engine.

Spawns 3 parallel AI agents to explore a topic from different angles:
  Technical Architect  → Architecture, feasibility, implementation
  Market Strategist    → Market fit, competition, value proposition
  UX Designer          → User flows, interaction, accessibility

Synthesizes into 2-3 concrete approaches with trade-offs and recommendations.

Usage:
  zes brainstorm "topic"
  zes brainstorm "topic" --output ~/designs/
  zes brainstorm "topic" --save-only    # Just write design doc, no interactive
  zes brainstorm "topic" --quick        # Local context only, skip AI
"""

import asyncio, json, os, sys, argparse, textwrap, subprocess
from datetime import datetime
from pathlib import Path
from typing import Optional

# ─── AI Provider Config ──────────────────────────────────────────

BRAINSTORM_PROVIDERS = {
    "technical": {
        "url": os.environ.get("TECH_URL", "https://api.groq.com/openai/v1/chat/completions"),
        "model": os.environ.get("TECH_MODEL", "llama-3.3-70b-versatile"),
        "env_key": "GROQ_API_KEY",
        "name": "Technical Architect (Groq Llama 3.3)",
    },
    "market": {
        "url": os.environ.get("MARKET_URL", "https://openrouter.ai/api/v1/chat/completions"),
        "model": os.environ.get("MARKET_MODEL", "deepseek/deepseek-v4-flash"),
        "env_key": "OPENROUTER_API_KEY",
        "name": "Market Strategist (OpenRouter DeepSeek V4)",
    },
    "ux": {
        "url": os.environ.get("UX_URL", "https://api.llm7.io/v1/chat/completions"),
        "model": os.environ.get("UX_MODEL", "codestral-latest"),
        "env_key": "LLM7_API_KEY",
        "name": "UX Designer (LLM7 Codestral)",
    },
}

# ─── Agent Prompts ───────────────────────────────────────────────

TECH_ARCHITECT_PROMPT = """You are the **Technical Architect** in a 3-agent Brainstorming team.

Your job: Analyze the topic from a technical/engineering perspective.

Think about:
1. **Architecture** — What components are needed? How do they interact? Data flow?
2. **Tech Stack** — What technologies, frameworks, libraries would work best?
3. **Feasibility** — How complex is this to build? What are the technical risks?
4. **Scalability** — Will this scale? What bottlenecks exist?
5. **Security** — What security considerations are there?
6. **Implementation** — What's the build order? What's the MVP?

Output a structured analysis:
```
TECHNICAL ANALYSIS
─────────────────
ARCHITECTURE: [high-level design description]
COMPONENTS: [list of key components and their responsibilities]
TECH_STACK: [recommended technologies with rationale]
FEASIBILITY: [easy | moderate | complex | very complex]
TECH_RISKS: [top 3 technical risks]
MVP_SCOPE: [what a minimum viable version looks like]
ESTIMATE: [rough implementation phases and timeline]
```"""

MARKET_STRATEGIST_PROMPT = """You are the **Market Strategist** in a 3-agent Brainstorming team.

Your job: Analyze the topic from a business/market perspective.

Think about:
1. **Market Need** — What problem does this solve? Who needs it?
2. **Target Users** — Who are the primary and secondary users?
3. **Competition** — What alternatives exist? How is this different?
4. **Value Proposition** — Why would someone choose this?
5. **Business Model** — How could this be monetized or sustained?
6. **Growth** — How would adoption happen? What's the go-to-market?
7. **Risks** — What market risks exist? Regulatory?

Output a structured analysis:
```
MARKET ANALYSIS
───────────────
PROBLEM: [the core problem being solved]
TARGET_USERS: [primary and secondary user segments]
COMPETITION: [existing alternatives and how this differs]
VALUE_PROP: [unique value proposition in one sentence]
BUSINESS_MODEL: [how this would work as a product]
GO_TO_MARKET: [how to reach users and drive adoption]
MARKET_RISKS: [top 3 market/business risks]
OPPORTUNITY: [market size, growth potential, timing]
```"""

UX_DESIGNER_PROMPT = """You are the **UX Designer** in a 3-agent Brainstorming team.

Your job: Analyze the topic from a user experience/design perspective.

Think about:
1. **User Journey** — What are the key user flows? Entry point to goal completion?
2. **Interactions** — How does the user interact with the system? Inputs, feedback?
3. **Accessibility** — How can this be inclusive for all users?
4. **Visual Design** — What design language, patterns, or metaphors fit?
5. **Usability** — What makes this easy/hard to use? Cognitive load?
6. **User Research** — What assumptions need validation? What would you test?

Output a structured analysis:
```
UX ANALYSIS
───────────
USER_NEEDS: [what users actually need, not features]
KEY_FLOWS: [the 3 most important user journeys]
INTERACTION: [how users interact at each step]
DESIGN_PRINCIPLES: [guiding design principles for this project]
ACCESSIBILITY: [key accessibility considerations]
USABILITY_RISKS: [top 3 usability risks]
USERS_TO_TEST: [what user groups to validate with first]
```"""

SYNTHESIS_PROMPT = """You are the **Brainstorming Synthesizer**. Your job is to combine the 3 agent analyses into 2-3 concrete approaches with trade-offs.

TECHNICAL ANALYSIS:
{tech}

MARKET ANALYSIS:
{market}

UX ANALYSIS:
{ux}

TOPIC:
{topic}

Produce:
1. **2-3 Distinct Approaches** — For each approach:
   - Name and one-line description
   - Technical approach (what stack, architecture style)
   - Market angle (who it's for, how it's positioned)
   - UX philosophy (user experience paradigm)
   - Key trade-off (what's sacrificed vs gained)
   - Risk level (low/medium/high)

2. **Recommended Approach** — Which one you recommend and why

3. **Next Steps** — What to do first (validate, prototype, research)

Format as a clean markdown document ready to save as a design spec."""


# ─── HTTP Client ──────────────────────────────────────────────────

async def call_provider(name: str, prompt: str, timeout: int = 60) -> Optional[str]:
    """Call an AI brainstorming agent."""
    import urllib.request
    
    cfg = BRAINSTORM_PROVIDERS.get(name)
    if not cfg:
        return f"[ERROR: Unknown provider '{name}']"
    
    key = os.environ.get(cfg["env_key"])
    if not key:
        return f"[ERROR: Missing API key {cfg['env_key']}]"
    
    payload = {
        "model": cfg["model"],
        "messages": [
            {"role": "system", "content": "You are a creative brainstorming specialist. Be specific, concrete, and actionable. Use clear structure with sections and bullet points."},
            {"role": "user", "content": prompt},
        ],
        "temperature": 0.8,  # Higher temp for creative divergence
        "max_tokens": 2048,
    }
    
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {key}",
        "User-Agent": "ZES-Brainstorm/1.0",
    }
    
    if "openrouter" in name or "openrouter" in cfg.get("url", ""):
        headers["HTTP-Referer"] = "https://github.com/ZESCODE/Zes-Orchestration-System"
        headers["X-Title"] = "ZES Brainstorm Engine"
    
    try:
        data = json.dumps(payload).encode()
        req = urllib.request.Request(cfg["url"], data=data, headers=headers)
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            resp_data = json.loads(resp.read().decode())
            content = resp_data.get("choices", [{}])[0].get("message", {}).get("content", "")
            return content or "[No content returned]"
    except Exception as e:
        return f"[ERROR: {name} failed — {e}]"


# ─── Project Context ─────────────────────────────────────────────

def get_project_context(project_dir: Optional[str] = None) -> str:
    """Get project context if available."""
    if not project_dir or not os.path.isdir(project_dir):
        return ""
    
    parts = []
    root = Path(project_dir)
    
    # Read README
    for readme in ["README.md", "README.txt", "README"]:
        rp = root / readme
        if rp.exists():
            parts.append(f"README:\n{rp.read_text()[:2000]}")
            break
    
    # Check git info
    try:
        proc = subprocess.run(
            ["git", "log", "--oneline", "-5"],
            capture_output=True, text=True, timeout=5, cwd=project_dir
        )
        if proc.stdout.strip():
            parts.append(f"\nRECENT COMMITS:\n{proc.stdout.strip()}")
    except:
        pass
    
    # File listing
    files = list(root.rglob("*"))[:30]
    files = [f for f in files if f.is_file() and "node_modules" not in str(f) and ".git" not in str(f)]
    if files:
        parts.append(f"\nPROJECT FILES ({len(files)} total, showing first 20):")
        for f in files[:20]:
            parts.append(f"  {f.relative_to(project_dir)}")
    
    return "\n".join(parts)


# ─── Main Brainstorm Logic ───────────────────────────────────────

async def run_brainstorm(topic: str, project_dir: Optional[str] = None,
                         save_dir: Optional[str] = None, save_only: bool = False,
                         quick: bool = False, verbose: bool = False):
    """Run 3-agent brainstorming."""
    start = datetime.now()
    
    print(f"\n{'='*60}")
    print(f"  💡 ZES 3-Agent Brainstorming")
    print(f"{'='*60}")
    print(f"  Topic: {topic[:80]}{'...' if len(topic) > 80 else ''}")
    if project_dir:
        print(f"  Context: {project_dir}")
    print(f"  Time:   {start.strftime('%H:%M:%S')}")
    print(f"{'='*60}\n")
    
    # Gather context
    context = get_project_context(project_dir)
    if context:
        print(f"  📁 Project context loaded ({len(context)} chars)\n")
    
    # Build prompts with context
    topic_with_context = f"TOPIC: {topic}\n\nCONTEXT:\n{context[:2000]}" if context else f"TOPIC: {topic}"
    
    if quick:
        print(f"  ⚡ Quick mode — single synthesis only")
        quick_result = await call_provider("technical",
            f"Quick brainstorm on: {topic}\n\nGive 2-3 approaches with trade-offs and a recommendation. Be concise (max 500 words).\n\nContext:\n{context[:2000]}" if context else
            f"Quick brainstorm on: {topic}\n\nGive 2-3 approaches with trade-offs and a recommendation. Be concise (max 500 words).")
        print(f"\n  💡 QUICK BRAINSTORM")
        print(f"\n{textwrap.indent(quick_result.strip(), '  ')}")
        elapsed = (datetime.now() - start).total_seconds()
        print(f"\n{'='*60}")
        print(f"  ⏱ {elapsed:.0f}s")
        print(f"{'='*60}\n")
        return
    
    # Phase 1: 3 parallel agents
    print(f"  🚀 Launching 3 brainstorming agents...\n")
    
    agent_start = datetime.now()
    tasks = {
        "technical": call_provider("technical",
            f"{TECH_ARCHITECT_PROMPT}\n\nTopic to brainstorm:\n{topic_with_context}"),
        "market": call_provider("market",
            f"{MARKET_STRATEGIST_PROMPT}\n\nTopic to brainstorm:\n{topic_with_context}"),
        "ux": call_provider("ux",
            f"{UX_DESIGNER_PROMPT}\n\nTopic to brainstorm:\n{topic_with_context}"),
    }
    
    results = await asyncio.gather(*[tasks[k] for k in ["technical", "market", "ux"]])
    agent_elapsed = (datetime.now() - agent_start).total_seconds()
    
    tech_result, market_result, ux_result = results
    
    # Phase 2: Synthesize
    synthesis_input = {
        "tech": tech_result[:3000] if not tech_result.startswith("[ERROR") else "Agent unavailable",
        "market": market_result[:3000] if not market_result.startswith("[ERROR") else "Agent unavailable",
        "ux": ux_result[:3000] if not ux_result.startswith("[ERROR") else "Agent unavailable",
        "topic": topic,
    }
    
    synthesis_prompt = SYNTHESIS_PROMPT.format(**synthesis_input)
    synthesis_result = await call_provider("technical", synthesis_prompt)
    synthesis_result = synthesis_result or "[No synthesis available]"
    
    total_elapsed = (datetime.now() - start).total_seconds()
    
    # Phase 3: Generate document
    doc = f"""# Brainstorming: {topic}

**Generated:** {datetime.now().strftime('%Y-%m-%d %H:%M')}
**Agents:** Technical Architect (Groq) + Market Strategist (OpenRouter) + UX Designer (LLM7)
**Duration:** {total_elapsed:.0f}s

---

## 1. Perspectives

### 🔧 Technical Perspective
{tech_result.strip() if not tech_result.startswith('[ERROR') else '*Agent unavailable*'}

### 📈 Market Perspective
{market_result.strip() if not market_result.startswith('[ERROR') else '*Agent unavailable*'}

### 🎨 UX Perspective
{ux_result.strip() if not ux_result.startswith('[ERROR') else '*Agent unavailable*'}

---

## 2. Synthesized Approaches

{synthesis_result.strip()}

---

*Generated by ZES 3-Agent Brainstorming Engine*
"""
    
    # Save document
    if save_dir:
        save_path = Path(save_dir)
    else:
        save_path = Path.cwd() / "docs" / "superpowers" / "specs"
    
    save_path.mkdir(parents=True, exist_ok=True)
    filename = f"{datetime.now().strftime('%Y-%m-%d')}-{topic.lower().replace(' ', '-')[:40]}-brainstorm.md"
    filepath = save_path / filename
    filepath.write_text(doc)
    
    # ─── Output ────────────────────────────────────────────────
    print(f"\n{'='*60}")
    print(f"  💡 BRAINSTORMING REPORT ({total_elapsed:.0f}s)")
    print(f"{'='*60}\n")
    
    print(f"  ┌{'─'*56}┐")
    print(f"  │ 🔧 TECHNICAL ARCHITECT                                │")
    print(f"  └{'─'*56}┘")
    print(f"\n{textwrap.indent(tech_result.strip(), '  ')}")
    
    print(f"\n")
    print(f"  ┌{'─'*56}┐")
    print(f"  │ 📈 MARKET STRATEGIST                                  │")
    print(f"  └{'─'*56}┘")
    print(f"\n{textwrap.indent(market_result.strip(), '  ')}")
    
    print(f"\n")
    print(f"  ┌{'─'*56}┐")
    print(f"  │ 🎨 UX DESIGNER                                        │")
    print(f"  └{'─'*56}┘")
    print(f"\n{textwrap.indent(ux_result.strip(), '  ')}")
    
    print(f"\n")
    print(f"  ┌{'─'*56}┐")
    print(f"  │ 🧩 SYNTHESIZED APPROACHES                              │")
    print(f"  └{'─'*56}┘")
    print(f"\n{textwrap.indent(synthesis_result.strip(), '  ')}")
    
    print(f"\n{'='*60}")
    print(f"  ⏱ {total_elapsed:.0f}s | Agents: {agent_elapsed:.0f}s | Synthesis: {total_elapsed - agent_elapsed:.0f}s")
    print(f"  📄 Saved: {filepath}")
    print(f"{'='*60}\n")
    
    return doc


# ─── CLI ──────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        description="ZES 3-Agent Brainstorming — Technical + Market + UX perspectives, synthesized into approaches",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            Examples:
              zes brainstorm "Build a CLI tool for project scaffolding"
              zes brainstorm "AI-powered code review bot" --dir ~/project
              zes brainstorm "Markdown note-taking app" --output ~/designs/
              zes brainstorm "Feature: real-time collaboration" --quick
        """),
    )
    parser.add_argument("topic", nargs="+", help="Topic or idea to brainstorm")
    parser.add_argument("--dir", "-d", help="Project directory for context")
    parser.add_argument("--output", "-o", help="Output directory for design doc")
    parser.add_argument("--save-only", action="store_true", 
                        help="Save doc without full terminal output")
    parser.add_argument("--quick", "-q", action="store_true",
                        help="Single synthesis instead of 3-agent (faster)")
    parser.add_argument("--verbose", "-v", action="store_true", help="Verbose")
    
    args = parser.parse_args()
    
    topic = " ".join(args.topic)
    if not topic:
        parser.print_help()
        sys.exit(1)
    
    asyncio.run(run_brainstorm(topic, args.dir, args.output, args.save_only, args.quick, args.verbose))


if __name__ == "__main__":
    main()